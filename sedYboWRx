modules = ["nodejs-20", "bash", "web", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["stripe:2.0.0", "javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["unzip", "bind"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
# publicDir = "out"  # Removed: backend serves static files
run = ["node", "--import", "tsx", "server/index.ts"]

[userenv]

[userenv.shared]
VITE_QA_AUTO_LOGIN = "false"
VITE_DEMO_USER_ID = ""
BOOTSTRAP_SUPER_ADMIN_EMAIL = "admin@cardxc.com"

[userenv.development]
VITE_PRE_PUBLISH_PREVIEW = "false"
