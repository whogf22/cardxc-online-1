# Public frontend URLs (safe to commit)
VITE_API_URL=https://api.yourdomain.com/api
VITE_PUBLIC_SITE_URL=https://yourdomain.com
VITE_APP_DOMAIN=yourdomain.com
VITE_ADMIN_DOMAIN=admin.yourdomain.com

# NEVER commit real secrets
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
VITE_STRIPE_PUBLIC_KEY=pk_live_REPLACE_ME
DATABASE_URL=postgres://user:password@host:5432/dbname
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=REPLACE_ME
